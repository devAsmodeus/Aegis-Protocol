# Aegis Protocol — example environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ───────────────────────────────────────────────────────────────────────────
# App
# ───────────────────────────────────────────────────────────────────────────
APP_NAME=aegis-protocol
APP_ENV=development           # development | staging | production
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ───────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_password@localhost:5432/aegis

# ───────────────────────────────────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────────────────────────────
# Qdrant (vector store)
# ───────────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# 0G — Storage / Compute / DA / Chain
# Fill these in Day 2 after reading 0G docs and getting testnet credentials.
# ───────────────────────────────────────────────────────────────────────────
ZEROG_RPC_URL=
ZEROG_STORAGE_ENDPOINT=
ZEROG_COMPUTE_ENDPOINT=
ZEROG_DA_ENDPOINT=
ZEROG_API_KEY=
ZEROG_PRIVATE_KEY=            # testnet only — never use mainnet keys here

# ───────────────────────────────────────────────────────────────────────────
# ENS (Day 6+)
# ───────────────────────────────────────────────────────────────────────────
ENS_PARENT_DOMAIN=             # e.g. aegis-protocol.eth
ETH_RPC_URL=                   # mainnet or sepolia, for ENS resolution

# ───────────────────────────────────────────────────────────────────────────
# Channel adapters (Day 5)
# ───────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ───────────────────────────────────────────────────────────────────────────
# Observability
# ───────────────────────────────────────────────────────────────────────────
SENTRY_DSN=

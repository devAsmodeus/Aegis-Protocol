# Aegis Protocol — example environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ───────────────────────────────────────────────────────────────────────────
# App
# ───────────────────────────────────────────────────────────────────────────
APP_NAME=aegis-protocol
APP_ENV=development           # development | staging | production
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ───────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_password@localhost:5432/aegis

# ───────────────────────────────────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────────────────────────────
# Qdrant (vector store)
# ───────────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# 0G — Storage / Compute / DA / Chain
# Fill these in Day 2 after reading 0G docs and getting testnet credentials.
# ───────────────────────────────────────────────────────────────────────────
ZEROG_RPC_URL=
ZEROG_STORAGE_ENDPOINT=
ZEROG_COMPUTE_ENDPOINT=
ZEROG_DA_ENDPOINT=
ZEROG_API_KEY=
ZEROG_PRIVATE_KEY=            # testnet only — never use mainnet keys here

# ───────────────────────────────────────────────────────────────────────────
# ENS (Day 6+)
# ───────────────────────────────────────────────────────────────────────────
ENS_PARENT_DOMAIN=             # e.g. aegis-protocol.eth
ETH_RPC_URL=                   # mainnet or sepolia, for ENS resolution

# ───────────────────────────────────────────────────────────────────────────
# Channel adapters (Day 5)
# Optional. Install the matching extra: `uv sync --extra telegram` /
# `uv sync --extra discord`. Without a token the corresponding adapter
# stays inactive.
# ───────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ───────────────────────────────────────────────────────────────────────────
# Keeper webhook (Day 8 — KeeperHub track)
# HMAC-SHA256 secret used by `/v1/keeper/tasks/{name}/run`. The route
# computes `hmac.sha256(secret, raw_body)` and compares it to the
# `X-Aegis-Keeper-Signature` header. If unset, the route returns 503
# (never an open default).
# ───────────────────────────────────────────────────────────────────────────
KEEPER_SIGNING_SECRET=

# ───────────────────────────────────────────────────────────────────────────
# Admin API (Day 8)
# Bearer token for `/v1/admin/*`. If unset, those routes return 503.
# Compared in constant time against the `Authorization: Bearer <token>`
# header. Rotate by changing this value and restarting the process.
# ───────────────────────────────────────────────────────────────────────────
ADMIN_API_TOKEN=

# ───────────────────────────────────────────────────────────────────────────
# Observability
# ───────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
